# ═══════════════════════════════════════════════════════════════════════════
# Crypto Monitor — variáveis de ambiente (EXEMPLO)
# Copie este arquivo para `.env` e preencha com os valores reais.
# NUNCA versione o `.env` (já está no .gitignore).
# ═══════════════════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────────────
# URL e chaves do projeto Supabase (Project Settings → API).
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=cole_a_anon_key_aqui
# service_role: USADA SOMENTE PELO COLETOR (backend). Nunca exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_aqui

# ─── IA — Google Gemini ─────────────────────────────────────────────────────
# Usada pela Edge Function generate-analysis (secret no Supabase, não no coletor).
# Modelos por plano: free=gemini-2.0-flash, pro=gemini-2.5-flash, expert=gemini-2.5-pro.
GEMINI_API_KEY=cole_a_chave_gemini_aqui

# ─── Fontes de dados que exigem chave ──────────────────────────────────────
# Coinalyze: chave gratuita, 40 calls/min (derivativos agregados).
COINALYZE_API_KEY=cole_a_chave_coinalyze_aqui
# CoinGecko: chave Demo gratuita (10k calls/mês, 30 req/min).
COINGECKO_API_KEY=cole_a_chave_coingecko_demo_aqui
# (Binance, Coinbase, Deribit, DefiLlama, Alternative.me, Hyperliquid,
#  DexScreener e Cryptocurrency.cv não exigem chave.)

# ─── Pagamentos — Mercado Pago (Fase 5) ────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=cole_o_access_token_aqui
MERCADOPAGO_WEBHOOK_SECRET=defina_um_segredo_de_webhook_aqui

# ─── Alertas — e-mail (Pro) ────────────────────────────────────────────────
# Resend: envio de e-mails transacionais/alertas.
RESEND_API_KEY=re_cole_a_chave_aqui
ALERTS_FROM_EMAIL=alertas@seudominio.com.br

# ─── Alertas — WhatsApp (Expert) via Evolution API ─────────────────────────
EVOLUTION_API_URL=https://sua-instancia-evolution.com.br
EVOLUTION_API_KEY=cole_a_chave_evolution_aqui
EVOLUTION_INSTANCE=crypto-monitor

# ─── Configuração do coletor ───────────────────────────────────────────────
# Intervalo do ciclo principal (minutos). PRD: 5 min.
COLLECT_INTERVAL_MINUTES=5
# Macro (CoinGecko) coletado em ciclo mais espaçado para respeitar o rate limit.
MACRO_INTERVAL_MINUTES=15
# Ativos monitorados no MVP (separados por vírgula).
ASSETS=BTC,ETH,SOL
# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# Frontend (Vite) — variáveis com prefixo VITE_ ficam EXPOSTAS no bundle.
# Use somente chaves públicas aqui (jamais a service_role).
# ═══════════════════════════════════════════════════════════════════════════
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole_a_anon_key_aqui
