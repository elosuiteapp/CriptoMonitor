---
import { SIGNUP_URL } from "../consts";
import T from "./T.astro";
const year = 2026;
---

<footer class="border-t border-line/70 bg-surface/40">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <div class="flex items-center gap-2.5">
          <span
            class="grid h-8 w-8 place-items-center rounded-lg bg-gradient-to-br from-primary-strong to-primary text-sm font-bold text-white"
            >OV</span
          >
          <span class="text-lg font-bold tracking-tight">OrbeView</span>
        </div>
        <p class="mt-3 text-sm text-muted">
          <T
            pt="O cockpit institucional dos mercados — cripto, ações (B3) e câmbio. Dados complexos traduzidos em leitura clara."
            en="The institutional cockpit for the markets — crypto, stocks (B3), and forex. Complex data turned into a clear read."
          />
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 text-sm sm:grid-cols-3">
        <div>
          <div class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted"><T pt="Produto" en="Product" /></div>
          <ul class="space-y-2 text-muted">
            <li><a href="/#recursos" class="transition-colors hover:text-fg"><T pt="Recursos" en="Features" /></a></li>
            <li><a href="/precos" class="transition-colors hover:text-fg"><T pt="Preços" en="Pricing" /></a></li>
            <li><a href="/newsletter" class="transition-colors hover:text-fg">Newsletter</a></li>
          </ul>
        </div>
        <div>
          <div class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted"><T pt="Conta" en="Account" /></div>
          <ul class="space-y-2 text-muted">
            <li><a href={SIGNUP_URL} class="transition-colors hover:text-fg"><T pt="Criar conta" en="Create account" /></a></li>
            <li><a href={SIGNUP_URL} class="transition-colors hover:text-fg"><T pt="Entrar" en="Log in" /></a></li>
          </ul>
        </div>
        <div>
          <div class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted">Legal</div>
          <ul class="space-y-2 text-muted">
            <li><a href="/termos" class="transition-colors hover:text-fg"><T pt="Termos" en="Terms" /></a></li>
            <li><a href="/termos#reembolso" class="transition-colors hover:text-fg"><T pt="Reembolso" en="Refunds" /></a></li>
            <li><a href="/privacidade" class="transition-colors hover:text-fg"><T pt="Privacidade" en="Privacy" /></a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-line/70 pt-6 text-xs text-muted">
      <p>
        <T
          html
          pt='As informações e leituras do OrbeView têm caráter <strong class="text-fg/80">informativo e educacional</strong>. Não constituem recomendação de compra ou venda, nem aconselhamento financeiro ou de investimento. Quem decide é sempre você.'
          en='OrbeView&apos;s information and reads are provided for <strong class="text-fg/80">informational and educational purposes</strong> only. They are not buy or sell recommendations, nor financial or investment advice. The decision is always yours.'
        />
      </p>
      <p class="mt-3">© {year} OrbeView. <T pt="Todos os direitos reservados." en="All rights reserved." /></p>
    </div>
  </div>
</footer>
