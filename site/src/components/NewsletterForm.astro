---
// Inscrição na newsletter = cria conta Free via magic-link (Supabase OTP) + registra
// o assinante. 100% client-side com a anon key. Sem servidor.
import T from "./T.astro";
---

<form id="nl-form" class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row">
  <input
    id="nl-email"
    name="email"
    type="email"
    required
    autocomplete="email"
    placeholder="seu@email.com"
    class="w-full rounded-lg border border-line bg-card px-4 py-3 text-sm text-fg outline-none transition-colors focus:border-primary"
  />
  <button
    id="nl-btn"
    type="submit"
    class="shrink-0 rounded-lg bg-primary-strong px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-primary disabled:opacity-60"
  >
    <T pt="Quero receber" en="Subscribe" />
  </button>
</form>
<p id="nl-msg" class="mt-3 text-xs text-muted"><T pt="Sem spam. Cancele quando quiser." en="No spam. Unsubscribe anytime." /></p>

<script>
  import { supabase } from "../lib/supabase";
  import { APP_URL } from "../consts";

  const form = document.getElementById("nl-form") as HTMLFormElement | null;
  const emailEl = document.getElementById("nl-email") as HTMLInputElement | null;
  const btn = document.getElementById("nl-btn") as HTMLButtonElement | null;
  const msg = document.getElementById("nl-msg");

  const MSG = {
    pt: {
      unavailable: "Cadastro temporariamente indisponível. Tente em instantes.",
      sending: "Enviando…",
      done: "Pronto! Enviamos um link pro seu e-mail — confirme para ativar sua conta grátis e receber a newsletter.",
      fail: "Não foi possível inscrever agora. Tente novamente em instantes.",
    },
    en: {
      unavailable: "Sign-up is temporarily unavailable. Please try again in a moment.",
      sending: "Sending…",
      done: "Done! We've emailed you a link — confirm it to activate your free account and start getting the newsletter.",
      fail: "We couldn't subscribe you right now. Please try again in a moment.",
    },
  };
  const lang = () => (document.documentElement.getAttribute("data-lang") === "en" ? "en" : "pt");
  if (emailEl && lang() === "en") emailEl.placeholder = "you@email.com";

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!msg) return;
    const m = MSG[lang()];
    const email = (emailEl?.value || "").trim().toLowerCase();
    if (!email) return;
    if (!supabase) {
      msg.textContent = m.unavailable;
      return;
    }
    if (btn) btn.disabled = true;
    msg.textContent = m.sending;
    try {
      await supabase
        .from("newsletter_subscribers")
        .upsert({ email, source: "site" }, { onConflict: "email", ignoreDuplicates: true });
      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: { shouldCreateUser: true, emailRedirectTo: APP_URL },
      });
      if (error) throw error;
      msg.textContent = m.done;
      form.reset();
    } catch (_err) {
      msg.textContent = m.fail;
    } finally {
      if (btn) btn.disabled = false;
    }
  });
</script>
