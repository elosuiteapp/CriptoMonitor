---
// Corpo da home (compartilhado entre / e /en/ — both-in-DOM via <T>).
import Nav from "../Nav.astro";
import Footer from "../Footer.astro";
import NewsletterForm from "../NewsletterForm.astro";
import T from "../T.astro";
import { SIGNUP_URL, PRICING, MARKETS } from "../../consts";
import { PRICING_EN, MARKETS_EN } from "../../consts.en";

const brl = (n: number) => n.toLocaleString("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });

// Acento de cor por mercado (indigo/verde/âmbar). Classes LITERAIS aqui p/ o Tailwind
// detectar — não montar dinamicamente com template string.
const ACCENT: Record<string, string> = {
  crypto: "text-primary bg-primary/10 border-primary/30",
  b3: "text-up bg-up/10 border-up/30",
  forex: "text-amber-400 bg-amber-400/10 border-amber-400/30",
};

const STEPS = [
  { n: "1", title: { pt: "Crie sua conta grátis", en: "Create your free account" }, desc: { pt: "Comece pelo cockpit do BTC e pela newsletter semanal, sem cartão.", en: "Start with the BTC cockpit and the weekly newsletter — no card required." } },
  { n: "2", title: { pt: "Leia o mercado com clareza", en: "Read the market clearly" }, desc: { pt: "Gamma, fluxo e liquidez traduzidos em semáforo — sem precisar ser quant.", en: "Gamma, flow, and liquidity turned into a simple signal — no quant background needed." } },
  { n: "3", title: { pt: "Assine o que você usa", en: "Subscribe to what you use" }, desc: { pt: "Um módulo (Cripto, B3 ou Forex) libera tudo daquele mercado — ou leve os três no Completo por um preço só.", en: "One module (Crypto, B3, or Forex) unlocks everything in that market — or get all three in Complete for one price." } },
];

// Candles do mockup do hero (decorativo). t/b = topo/base do corpo; o pavio extrapola ±9.
const CANDLES = [
  { x: 20, t: 70, b: 120, up: true },
  { x: 40, t: 60, b: 100, up: true },
  { x: 60, t: 64, b: 112, up: false },
  { x: 80, t: 50, b: 92, up: true },
  { x: 100, t: 44, b: 78, up: true },
  { x: 120, t: 52, b: 96, up: false },
  { x: 140, t: 58, b: 104, up: false },
  { x: 160, t: 66, b: 118, up: true },
  { x: 180, t: 60, b: 98, up: true },
  { x: 200, t: 48, b: 84, up: true },
  { x: 220, t: 54, b: 100, up: false },
  { x: 240, t: 62, b: 108, up: false },
  { x: 260, t: 70, b: 116, up: true },
  { x: 280, t: 64, b: 102, up: true },
  { x: 300, t: 58, b: 94, up: false },
];
---

<Nav />

<!-- Hero -->
<section class="glow relative overflow-hidden">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 lg:grid-cols-2 lg:py-28">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full border border-line bg-card px-3 py-1 text-xs text-muted">
        <span class="h-1.5 w-1.5 rounded-full bg-up"></span> <T pt="Dados institucionais, leitura simples" en="Institutional data, simple to read" />
      </span>
      <h1 class="mt-5 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl">
        <T
          html
          pt={'O cockpit institucional<br /> dos <span class="text-primary">mercados</span>.'}
          en={'The institutional cockpit for the <span class="text-primary">markets</span>.'}
        />
      </h1>
      <p class="mt-5 max-w-md text-lg text-muted">
        <T
          pt="OrbeView traduz gamma, smart money e fluxo de capital em uma leitura clara — para você decidir com a visão de quem move o mercado. Cripto, ações (B3) e câmbio (Forex): os três no ar."
          en="OrbeView turns gamma, smart money, and capital flow into a clear read — so you can decide with the perspective of those who move the market. Crypto, stocks (B3), and forex — all three live."
        />
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={SIGNUP_URL} class="btn-glow rounded-lg bg-primary-strong px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-primary">
          <T pt="Criar conta grátis" en="Create free account" />
        </a>
        <a href="/precos" class="btn-glow rounded-lg border border-line px-5 py-3 text-sm font-semibold text-fg hover:bg-card">
          <T pt="Ver planos" en="See plans" />
        </a>
      </div>
      <p class="mt-3 text-xs text-muted"><T pt="Grátis para sempre no plano Free · sem cartão" en="Free forever on the Free plan · no card" /></p>
    </div>

    <!-- Mock do cockpit (SVG) -->
    <div class="relative">
      <div class="card-lift rounded-2xl border border-line bg-card/80 p-4 shadow-2xl backdrop-blur">
        <div class="mb-3 flex items-center justify-between text-xs text-muted">
          <span class="flex items-center gap-1.5 font-semibold text-fg"><span class="livedot"></span>BTC · Bitcoin</span>
          <span class="num text-muted">4H</span>
        </div>
        <svg viewBox="0 0 320 170" class="mock-chart h-44 w-full" preserveAspectRatio="none">
          <!-- faixa heat (zona short acima / long abaixo) -->
          <rect x="0" y="18" width="320" height="26" fill="rgba(34,197,94,0.10)"></rect>
          <rect x="0" y="128" width="320" height="26" fill="rgba(239,68,68,0.10)"></rect>
          <!-- níveis -->
          <line x1="0" y1="30" x2="320" y2="30" stroke="#22c55e" stroke-width="1" stroke-dasharray="4 4"></line>
          <line x1="0" y1="86" x2="320" y2="86" stroke="#818cf8" stroke-width="1" stroke-dasharray="4 4"></line>
          <line x1="0" y1="140" x2="320" y2="140" stroke="#ef4444" stroke-width="1" stroke-dasharray="4 4"></line>
          <!-- velas -->
          <g>
            {CANDLES.map((k) => {
              const color = k.up ? "#22c55e" : "#ef4444";
              return (
                <g class="candle">
                  <line x1={k.x} y1={k.t - 9} x2={k.x} y2={k.b + 9} stroke={color} stroke-width="1.4"></line>
                  <rect x={k.x - 4} y={k.t} width="8" height={k.b - k.t} rx="1.5" fill={color}></rect>
                </g>
              );
            })}
          </g>
        </svg>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <span class="rounded-full border border-up/30 bg-up/10 px-2 py-0.5 text-[10px] text-up">Call Wall 80k</span>
          <span class="rounded-full border border-primary/30 bg-primary/15 px-2 py-0.5 text-[10px] text-primary">Zero Gamma <T pt="65,4k" en="65.4k" /></span>
          <span class="rounded-full border border-down/30 bg-down/10 px-2 py-0.5 text-[10px] text-down">Put Wall 60k</span>
        </div>
      </div>
      <div class="pointer-events-none absolute -bottom-3 -right-3 -z-10 h-full w-full rounded-2xl border border-line/60"></div>
    </div>
  </div>
</section>

<!-- Mercados — switcher interativo (Crypto no ar; B3/Forex em breve) -->
<section id="mercados" class="border-y border-line/70 bg-surface/30">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <p class="text-center text-sm text-muted"><T pt="Um cockpit, vários mercados — clique para conhecer cada um" en="One cockpit, many markets — click to explore each one" /></p>

    <!-- Abas -->
    <div class="mt-5 flex flex-wrap items-center justify-center gap-2.5">
      {MARKETS.map((m, i) => (
        <button
          type="button"
          data-market-tab={m.id}
          class:list={[
            "market-tab chip-lift inline-flex items-center gap-2 rounded-full border bg-card px-4 py-2 text-sm transition-colors",
            i === 0 ? "border-primary text-primary font-semibold" : "border-line text-muted",
          ]}
        >
          <span aria-hidden>{m.icon}</span>
          <span class="font-medium"><T pt={m.label} en={MARKETS_EN[i].label} /></span>
          <span class="text-[9px] uppercase tracking-wider text-muted"><T pt={m.note} en={MARKETS_EN[i].note} /></span>
        </button>
      ))}
    </div>

    <!-- Painéis -->
    <div class="mt-8">
      {MARKETS.map((m, i) => (
        <div data-market-panel={m.id} class:list={["market-panel mx-auto max-w-3xl", i === 0 ? "" : "hidden"]}>
          <div class="rounded-2xl border border-line bg-card p-6 sm:p-8">
            <div class="flex items-center gap-3">
              <span class="text-2xl" aria-hidden>{m.icon}</span>
              <div>
                <h3 class="text-lg font-bold"><T pt={m.label} en={MARKETS_EN[i].label} /></h3>
                <p class="text-sm text-muted"><T pt={m.tagline} en={MARKETS_EN[i].tagline} /></p>
              </div>
              <span
                class:list={[
                  "ml-auto shrink-0 rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider",
                  m.live ? "border-line text-up" : "border-line text-primary",
                ]}
              >
                {m.live ? <T pt="No ar" en="Live" /> : <T pt="Em breve" en="Coming soon" />}
              </span>
            </div>
            <ul class="mt-5 grid gap-2.5 sm:grid-cols-2">
              {m.points.map((p, j) => (
                <li class="flex gap-2 text-sm text-muted"><span class="mt-0.5 text-primary">▹</span><span><T pt={p} en={MARKETS_EN[i].points[j]} /></span></li>
              ))}
            </ul>
            <div class="mt-6">
              {m.live ? (
                <a href={SIGNUP_URL} class="btn-glow inline-block rounded-lg bg-primary-strong px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary"><T pt="Abrir o cockpit grátis" en="Open the cockpit for free" /></a>
              ) : (
                <a href="#newsletter" class="inline-flex items-center gap-2 rounded-lg border border-line px-5 py-2.5 text-sm font-semibold text-fg hover:bg-surface"><T pt="Quero ser avisado no lançamento →" en="Notify me at launch →" /></a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Recursos — o que cada módulo entrega (troca junto com o switcher de mercados) -->
<section id="recursos" class="mx-auto max-w-6xl px-4 py-20">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight"><T pt="As ferramentas que faltavam pro varejo" en="The tools retail was missing" /></h2>
    <p class="mt-3 text-muted"><T pt="Cada mercado é um mundo — então cada módulo traz o que a mesa institucional dele usa, num semáforo que qualquer trader entende. Escolha o mercado acima; o Free mostra uma prévia." en="Every market is its own world — so each module brings what its institutional desk uses, in a simple read any trader can follow. Pick a market above; Free gives you a preview." /></p>
  </div>

  {MARKETS.map((m, i) => (
    <div data-market-features={m.id} class:list={["market-features", i === 0 ? "" : "hidden"]}>
      <div class="mt-10 flex justify-center">
        <span class:list={["inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5 text-xs font-semibold", ACCENT[m.id]]}>
          <span aria-hidden>{m.icon}</span>
          <T pt={m.label} en={MARKETS_EN[i].label} />
        </span>
      </div>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {m.features.map((f, j) => (
          <div class="card-lift rounded-2xl border border-line bg-card p-6">
            <div class:list={["icon-pop grid h-11 w-11 place-items-center rounded-xl border text-xl", ACCENT[m.id]]} aria-hidden>{f.icon}</div>
            <h3 class="mt-4 font-semibold"><T pt={f.title} en={MARKETS_EN[i].features[j].title} /></h3>
            <p class="mt-1.5 text-sm text-muted"><T pt={f.desc} en={MARKETS_EN[i].features[j].desc} /></p>
          </div>
        ))}
      </div>
    </div>
  ))}

  <p class="mx-auto mt-10 max-w-2xl text-center text-sm text-muted">
    <T pt="Em todos os módulos: a IA costura tudo numa leitura em português + alertas (in-app, push e e-mail)." en="In every module: AI stitches it all into a plain-language read + alerts (in-app, push, and email)." />
  </p>
</section>

<!-- Como funciona -->
<section class="border-y border-line/70 bg-surface/30">
  <div class="mx-auto max-w-6xl px-4 py-20">
    <div class="grid gap-10 md:grid-cols-3">
      {STEPS.map((s) => (
        <div class="step">
          <div class="step-num grid h-9 w-9 place-items-center rounded-full bg-primary-strong text-sm font-bold text-white">{s.n}</div>
          <h3 class="mt-4 text-lg font-semibold"><T pt={s.title.pt} en={s.title.en} /></h3>
          <p class="mt-1.5 text-sm text-muted"><T pt={s.desc.pt} en={s.desc.en} /></p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Preços (teaser) -->
<section id="precos" class="mx-auto max-w-6xl px-4 py-20">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight"><T pt="Planos" en="Plans" /></h2>
    <p class="mt-3 text-muted"><T pt="Comece grátis. Assine um módulo ou leve os três no Completo. O anual sai mais barato." en="Start free. Subscribe to one module or get all three in Complete. Annual is cheaper." /></p>
  </div>
  <div class="mt-12 grid gap-5 lg:grid-cols-3">
    {PRICING.plans.map((p, i) => (
      <div class={`card-lift rounded-2xl border p-6 ${p.highlight ? "border-primary bg-card shadow-2xl ring-1 ring-primary/30" : "border-line bg-card"}`}>
        {p.highlight && <span class="mb-3 inline-block rounded-full border border-primary px-2.5 py-0.5 text-[11px] font-semibold text-primary"><T pt="Mais popular" en="Most popular" /></span>}
        <h3 class="text-lg font-bold">{p.name}</h3>
        <p class="mt-1 text-sm text-muted"><T pt={p.tagline} en={PRICING_EN.plans[i].tagline} /></p>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="num text-3xl font-extrabold">
            {p.monthly === 0 ? <T pt="Grátis" en="Free" /> : <T pt={brl(p.monthly)} en={`$${PRICING_EN.plans[i].usd}`} />}
          </span>
          {p.monthly > 0 && <span class="text-sm text-muted"><T pt="/mês" en="/mo" /></span>}
        </div>
        {p.monthly > 0 && (
          <p class="mt-1 text-xs text-muted"><T pt="ou" en="or" /> <span class="num text-fg"><T pt={brl(p.annual)} en={`$${PRICING_EN.plans[i].usdAnnual}`} /></span><T pt="/mês no anual" en="/mo billed annually" /></p>
        )}
        <ul class="mt-5 space-y-2 text-sm">
          {p.features.map((f, j) => (
            <li class="flex gap-2 text-muted"><span class="text-up">✓</span><span><T pt={f} en={PRICING_EN.plans[i].features[j]} /></span></li>
          ))}
        </ul>
        <a
          href={p.slug === "free" ? SIGNUP_URL : `${SIGNUP_URL}?plan=${p.slug}`}
          class={`mt-6 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors ${p.highlight ? "bg-primary-strong text-white hover:bg-primary" : "border border-line text-fg hover:bg-surface"}`}
        >
          <T pt={p.cta} en={PRICING_EN.plans[i].cta} />
        </a>
      </div>
    ))}
  </div>
  <p class="mt-6 text-center text-sm"><a href="/precos" class="text-primary hover:underline"><T pt="Comparar planos em detalhe →" en="Compare plans in detail →" /></a></p>
</section>

<!-- Newsletter -->
<section id="newsletter" class="border-y border-line/70 bg-surface/30">
  <div class="mx-auto max-w-2xl px-4 py-20 text-center">
    <h2 class="text-3xl font-bold tracking-tight"><T pt="A leitura semanal do mercado" en="The market's weekly read" /></h2>
    <p class="mt-3 text-muted">
      <T
        pt="Toda semana, uma edição traduzindo o que a mesa institucional está vendo — gamma, fluxo e liquidez. Grátis para quem tem conta."
        en="Every week, an edition that decodes what the institutional desk is seeing — gamma, flow, and liquidity. Free with any account."
      />
    </p>
    <div class="mt-8"><NewsletterForm /></div>
  </div>
</section>

<!-- CTA final -->
<section class="mx-auto max-w-6xl px-4 py-24 text-center">
  <h2 class="text-3xl font-bold tracking-tight sm:text-4xl"><T pt="Veja o mercado como a mesa vê." en="See the market the way the desk does." /></h2>
  <p class="mx-auto mt-3 max-w-md text-muted"><T pt="Crie sua conta grátis e abra o cockpit do BTC agora." en="Create your free account and open the BTC cockpit now." /></p>
  <a href={SIGNUP_URL} class="btn-glow mt-8 inline-block rounded-lg bg-primary-strong px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-primary">
    <T pt="Começar grátis" en="Start free" />
  </a>
</section>

<Footer />

<script>
  // Switcher de mercados: troca a aba, o painel-resumo E o grid de ferramentas ao
  // clicar. Crypto é o padrão. As ferramentas (#recursos) espelham o mercado ativo.
  const tabs = document.querySelectorAll<HTMLButtonElement>("[data-market-tab]");
  const panels = document.querySelectorAll<HTMLElement>("[data-market-panel]");
  const featurePanels = document.querySelectorAll<HTMLElement>("[data-market-features]");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const id = tab.dataset.marketTab;
      tabs.forEach((t) => {
        const on = t === tab;
        t.classList.toggle("border-primary", on);
        t.classList.toggle("text-primary", on);
        t.classList.toggle("font-semibold", on);
        t.classList.toggle("border-line", !on);
        t.classList.toggle("text-muted", !on);
      });
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.marketPanel !== id));
      featurePanels.forEach((p) => p.classList.toggle("hidden", p.dataset.marketFeatures !== id));
    });
  });
</script>

<style>
  /* Mockup "ao vivo" da hero — movimento sutil. Respeita prefers-reduced-motion. */
  .mock-chart .candle {
    animation: tick 2.8s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .mock-chart .candle:nth-child(2n) { animation-duration: 3.4s; animation-delay: -0.6s; }
  .mock-chart .candle:nth-child(3n) { animation-duration: 2.3s; animation-delay: -1.1s; }
  .mock-chart .candle:nth-child(5n) { animation-delay: -1.7s; }
  .mock-chart > line { animation: flow 2.6s linear infinite; }
  .mock-chart > rect { animation: heat 4s ease-in-out infinite; }

  .livedot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
    animation: pulse 1.8s ease-out infinite;
  }

  /* Realce ao passar o mouse: cards/chips/botoes sobem e ganham brilho da marca */
  .card-lift { transition: transform .35s cubic-bezier(.2, .7, .2, 1), box-shadow .35s ease, border-color .35s ease; }
  .card-lift:hover {
    transform: translateY(-6px);
    border-color: rgba(129, 140, 248, .55);
    box-shadow: 0 0 0 1px rgba(129, 140, 248, .35), 0 24px 50px -18px rgba(99, 102, 241, .45);
  }
  .card-lift .icon-pop { transition: transform .35s cubic-bezier(.2, .7, .2, 1); }
  .card-lift:hover .icon-pop { transform: translateY(-3px) scale(1.12); }

  .chip-lift { transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease; }
  .chip-lift:hover {
    transform: translateY(-3px);
    border-color: rgba(129, 140, 248, .5);
    box-shadow: 0 10px 22px -10px rgba(99, 102, 241, .5);
  }

  .btn-glow { transition: transform .22s ease, box-shadow .22s ease, background-color .2s ease; }
  .btn-glow:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -10px rgba(99, 102, 241, .6); }
  .btn-glow:active { transform: translateY(0); }

  .step .step-num { transition: transform .3s ease, box-shadow .3s ease; }
  .step:hover .step-num { transform: translateY(-3px) scale(1.08); box-shadow: 0 12px 26px -8px rgba(99, 102, 241, .6); }

  @keyframes tick { 0%, 100% { transform: scaleY(1); } 50% { transform: scaleY(1.16); } }
  @keyframes flow { to { stroke-dashoffset: -16; } }
  @keyframes heat { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
    100% { box-shadow: 0 0 0 7px rgba(34, 197, 94, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mock-chart .candle,
    .mock-chart > line,
    .mock-chart > rect,
    .livedot { animation: none; }
    .card-lift, .card-lift:hover, .card-lift .icon-pop, .card-lift:hover .icon-pop,
    .chip-lift, .chip-lift:hover, .btn-glow, .btn-glow:hover, .btn-glow:active,
    .step .step-num, .step:hover .step-num { transform: none; transition: none; }
  }
</style>
