---
// Corpo da página de Preços (compartilhado entre / e /en/ — both-in-DOM via <T>).
import Nav from "../Nav.astro";
import Footer from "../Footer.astro";
import T from "../T.astro";
import { SIGNUP_URL, PRICING, COMPARISON } from "../../consts";
import { PRICING_EN, COMPARISON_EN } from "../../consts.en";

const brl = (n: number) => n.toLocaleString("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });
---

<Nav />

<section class="mx-auto max-w-6xl px-4 py-16 lg:py-20">
  <div class="mx-auto max-w-2xl text-center">
    <h1 class="text-4xl font-extrabold tracking-tight"><T pt="Planos OrbeView" en="OrbeView plans" /></h1>
    <p class="mt-3 text-muted">
      <T
        html
        pt='Comece grátis. Assine <strong class="text-fg">1 módulo</strong> (Cripto, B3 ou Forex) ou leve <strong class="text-primary">os três no Completo</strong>. O plano anual sai mais barato.'
        en='Start free. Subscribe to <strong class="text-fg">1 module</strong> (Crypto, B3, or Forex) or get <strong class="text-primary">all three in Complete</strong>. The annual plan is cheaper.'
      />
    </p>
  </div>

  <div class="mt-12 grid items-start gap-5 lg:grid-cols-3">
    {PRICING.plans.map((p, i) => (
      <div class={`rounded-2xl border p-6 ${p.highlight ? "border-primary bg-card shadow-2xl ring-1 ring-primary/30" : "border-line bg-card"}`}>
        {p.highlight && <span class="mb-3 inline-block rounded-full border border-primary px-2.5 py-0.5 text-[11px] font-semibold text-primary"><T pt="Mais popular" en="Most popular" /></span>}
        <h2 class="text-xl font-bold">{p.name}</h2>
        <p class="mt-1 text-sm text-muted"><T pt={p.tagline} en={PRICING_EN.plans[i].tagline} /></p>

        <div class="mt-4 flex items-baseline gap-1">
          <span class="num text-4xl font-extrabold">
            {p.monthly === 0 ? <T pt="Grátis" en="Free" /> : <T pt={brl(p.monthly)} en={`$${PRICING_EN.plans[i].usd}`} />}
          </span>
          {p.monthly > 0 && <span class="text-sm text-muted"><T pt="/mês" en="/mo" /></span>}
        </div>
        {p.monthly > 0 && (
          <p class="mt-1 text-xs text-muted">
            <T pt="ou" en="or" /> <span class="num text-fg"><T pt={brl(p.annual)} en={`$${PRICING_EN.plans[i].usdAnnual}`} /></span><T pt="/mês no plano anual" en="/mo billed annually" />
          </p>
        )}

        <a
          href={p.slug === "free" ? SIGNUP_URL : `${SIGNUP_URL}?plan=${p.slug}`}
          class={`mt-5 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors ${p.highlight ? "bg-primary-strong text-white hover:bg-primary" : "border border-line text-fg hover:bg-surface"}`}
        >
          <T pt={p.cta} en={PRICING_EN.plans[i].cta} />
        </a>

        <ul class="mt-6 space-y-2.5 text-sm">
          {p.features.map((f, j) => (
            <li class="flex gap-2 text-muted"><span class="mt-0.5 text-up">✓</span><span><T pt={f} en={PRICING_EN.plans[i].features[j]} /></span></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Comparativo detalhado, recurso por recurso -->
  <div class="mt-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold tracking-tight"><T pt="Compare recurso por recurso" en="Compare feature by feature" /></h2>
      <p class="mt-2 text-sm text-muted"><T pt="Exatamente o que cada plano abre — sem letra miúda." en="Exactly what each plan unlocks — no fine print." /></p>
    </div>
    <div class="mt-8 overflow-x-auto rounded-2xl border border-line">
      <table class="w-full min-w-[680px] border-collapse text-sm">
        <thead>
          <tr class="bg-card">
            <th class="px-4 py-3 text-left font-semibold"><T pt="Recurso" en="Feature" /></th>
            <th class="px-3 py-3 text-center font-semibold">Free</th>
            <th class="px-3 py-3 text-center font-semibold"><T pt="1 Módulo" en="1 Module" /></th>
            <th class="bg-primary/[0.06] px-3 py-3 text-center font-semibold text-primary"><T pt="Completo" en="Complete" /></th>
          </tr>
        </thead>
        <tbody>
          {COMPARISON.map((g, gi) => (
            <Fragment>
              <tr>
                <td colspan="4" class="bg-surface/50 px-4 py-2 text-[11px] font-semibold uppercase tracking-wider text-muted"><T pt={g.group} en={COMPARISON_EN[gi].group} /></td>
              </tr>
              {g.rows.map((r, ri) => (
                <tr class="border-t border-line/50">
                  <td class="px-4 py-2.5 text-muted"><T pt={r.label} en={COMPARISON_EN[gi].rows[ri].label} /></td>
                  <td class="px-3 py-2.5 text-center">
                    {typeof r.free === "boolean" ? (r.free ? <span class="text-up">✓</span> : <span class="text-muted opacity-40">—</span>) : <span class="text-fg"><T pt={r.free} en={String(COMPARISON_EN[gi].rows[ri].free)} /></span>}
                  </td>
                  <td class="px-3 py-2.5 text-center">
                    {typeof r.module === "boolean" ? (r.module ? <span class="text-up">✓</span> : <span class="text-muted opacity-40">—</span>) : <span class="text-fg"><T pt={r.module} en={String(COMPARISON_EN[gi].rows[ri].module)} /></span>}
                  </td>
                  <td class="bg-primary/[0.06] px-3 py-2.5 text-center">
                    {typeof r.complete === "boolean" ? (r.complete ? <span class="text-up">✓</span> : <span class="text-muted opacity-40">—</span>) : <span class="font-medium text-fg"><T pt={r.complete} en={String(COMPARISON_EN[gi].rows[ri].complete)} /></span>}
                  </td>
                </tr>
              ))}
            </Fragment>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <p class="mx-auto mt-10 max-w-xl text-center text-xs text-muted">
    <T
      pt="Pagamento em reais via Pix, boleto ou cartão (Asaas). O plano mensal é cobrado no cartão de crédito (renovação automática). Cancele quando quiser, sem multa."
      en="Secure card payment (Paddle). The monthly plan auto-renews. Cancel anytime, no penalty."
    />
  </p>
</section>

<Footer />
