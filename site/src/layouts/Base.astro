---
import "../styles/global.css";
import "../styles/i18n.css";
import { SITE_URL } from "../consts";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "OrbeView — Cockpit dos mercados",
  description = "O cockpit institucional dos mercados: cripto, ações (B3) e câmbio. Traduz gamma, smart money e fluxo em leitura clara para decidir melhor.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE_URL).href;
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Idioma (PT/EN) ANTES do paint, sem flash. Resolve ?lang/?locale -> cookie
         .orbeview.com -> navegador. Mesma regra do app (useLocale). Persiste o
         cookie compartilhado para sincronizar com app.orbeview.com. -->
    <script is:inline>
      (function () {
        try {
          var q = new URLSearchParams(location.search);
          var p = q.get("lang") || q.get("locale");
          var m = document.cookie.match(/(?:^|; )ov_lang=([^;]*)/);
          var c = m ? decodeURIComponent(m[1]) : null;
          var nav = (navigator.language || "").toLowerCase();
          var lang = p === "pt" || p === "en" ? p : c === "pt" || c === "en" ? c : nav.indexOf("en") === 0 ? "en" : "pt";
          var d = document.documentElement;
          d.setAttribute("data-lang", lang);
          d.setAttribute("lang", lang === "en" ? "en" : "pt-BR");
          var dom = location.hostname.indexOf("orbeview.com") >= 0 ? "; Domain=.orbeview.com" : "";
          var sec = location.protocol === "https:" ? "; Secure" : "";
          document.cookie = "ov_lang=" + lang + "; Path=/; Max-Age=31536000; SameSite=Lax" + dom + sec;
        } catch (e) {}
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
