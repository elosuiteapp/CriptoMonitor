---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { SIGNUP_URL, PRICING, COMPARISON } from "../consts";

const brl = (n: number) => n.toLocaleString("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });
const annual = (monthly: number) => Math.round(monthly * 12 * (1 - PRICING.annualDiscount));
---

<Base title="Preços — OrbeView" description="Planos do OrbeView: Free, Pro e Expert. Comece grátis; anual com 30% OFF de lançamento.">
  <Nav />

  <section class="mx-auto max-w-6xl px-4 py-16 lg:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight">Planos OrbeView</h1>
      <p class="mt-3 text-muted">
        Comece grátis e suba quando quiser o cockpit completo. No plano <strong class="text-fg">anual</strong> você
        leva <strong class="text-primary">30% OFF</strong> de lançamento.
      </p>
    </div>

    <div class="mt-12 grid items-start gap-5 lg:grid-cols-3">
      {PRICING.plans.map((p) => (
        <div class={`rounded-2xl border p-6 ${p.highlight ? "border-primary bg-card shadow-2xl ring-1 ring-primary/30" : "border-line bg-card"}`}>
          {p.highlight && <span class="mb-3 inline-block rounded-full bg-primary/15 px-2.5 py-0.5 text-[11px] font-semibold text-primary">Mais popular</span>}
          <h2 class="text-xl font-bold">{p.name}</h2>
          <p class="mt-1 text-sm text-muted">{p.tagline}</p>

          <div class="mt-4 flex items-baseline gap-1">
            <span class="num text-4xl font-extrabold">{p.monthly === 0 ? "Grátis" : brl(p.monthly)}</span>
            {p.monthly > 0 && <span class="text-sm text-muted">/mês</span>}
          </div>
          {p.monthly > 0 && (
            <p class="mt-1 text-xs text-muted">
              ou <span class="num text-fg">{brl(annual(p.monthly))}</span>/ano · economize 30%
            </p>
          )}

          <a
            href={p.slug === "free" ? SIGNUP_URL : `${SIGNUP_URL}?plan=${p.slug}`}
            class={`mt-5 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors ${p.highlight ? "bg-primary-strong text-white hover:bg-primary" : "border border-line text-fg hover:bg-surface"}`}
          >
            {p.cta}
          </a>

          <ul class="mt-6 space-y-2.5 text-sm">
            {p.features.map((f) => (
              <li class="flex gap-2 text-muted"><span class="mt-0.5 text-up">✓</span><span>{f}</span></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Comparativo detalhado, recurso por recurso -->
    <div class="mt-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold tracking-tight">Compare recurso por recurso</h2>
        <p class="mt-2 text-sm text-muted">Exatamente o que cada plano abre — sem letra miúda.</p>
      </div>
      <div class="mt-8 overflow-x-auto rounded-2xl border border-line">
        <table class="w-full min-w-[680px] border-collapse text-sm">
          <thead>
            <tr class="bg-card">
              <th class="px-4 py-3 text-left font-semibold">Recurso</th>
              <th class="px-3 py-3 text-center font-semibold">Free</th>
              <th class="bg-primary/[0.06] px-3 py-3 text-center font-semibold text-primary">Pro</th>
              <th class="px-3 py-3 text-center font-semibold">Expert</th>
            </tr>
          </thead>
          <tbody>
            {COMPARISON.map((g) => (
              <Fragment>
                <tr>
                  <td colspan="4" class="bg-surface/50 px-4 py-2 text-[11px] font-semibold uppercase tracking-wider text-muted">{g.group}</td>
                </tr>
                {g.rows.map((r) => (
                  <tr class="border-t border-line/50">
                    <td class="px-4 py-2.5 text-muted">{r.label}</td>
                    <td class="px-3 py-2.5 text-center">
                      {typeof r.free === "boolean" ? (r.free ? <span class="text-up">✓</span> : <span class="text-muted opacity-40">—</span>) : <span class="text-fg">{r.free}</span>}
                    </td>
                    <td class="bg-primary/[0.06] px-3 py-2.5 text-center">
                      {typeof r.pro === "boolean" ? (r.pro ? <span class="text-up">✓</span> : <span class="text-muted opacity-40">—</span>) : <span class="font-medium text-fg">{r.pro}</span>}
                    </td>
                    <td class="px-3 py-2.5 text-center">
                      {typeof r.expert === "boolean" ? (r.expert ? <span class="text-up">✓</span> : <span class="text-muted opacity-40">—</span>) : <span class="text-fg">{r.expert}</span>}
                    </td>
                  </tr>
                ))}
              </Fragment>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mx-auto mt-10 max-w-xl text-center text-xs text-muted">
      Pagamento em reais via Pix, boleto ou cartão (Asaas). O plano mensal é cobrado no cartão de
      crédito (renovação automática). Cancele quando quiser, sem multa.
    </p>
  </section>

  <Footer />
</Base>
