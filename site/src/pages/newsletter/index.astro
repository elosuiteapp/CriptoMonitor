---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import NewsletterForm from "../../components/NewsletterForm.astro";
import { listEditions, fmtDate, TIER_LABEL } from "../../lib/newsletter";

const editions = await listEditions();
---

<Base
  title="Newsletter — OrbeView"
  description="A leitura semanal do mercado: gamma, fluxo institucional e liquidez traduzidos em português claro. Arquivo de edições do OrbeView."
>
  <Nav />
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-4xl font-extrabold tracking-tight">Newsletter</h1>
    <p class="mt-3 text-muted">
      A leitura semanal do mercado — o que a mesa institucional está vendo, traduzido em português
      claro.
    </p>

    <div class="mt-8 rounded-2xl border border-line bg-card p-5">
      <p class="text-sm font-semibold">Receba toda semana no seu e-mail</p>
      <p class="mb-3 mt-1 text-xs text-muted">Inscrever = conta grátis no OrbeView.</p>
      <NewsletterForm />
    </div>

    <div class="mt-12 space-y-4">
      {editions.length === 0 && (
        <p class="text-sm text-muted">
          Em breve as primeiras edições. Inscreva-se acima para não perder a primeira.
        </p>
      )}
      {editions.map((e) => (
        <a
          href={`/newsletter/${e.slug}`}
          class="block rounded-2xl border border-line bg-card p-5 transition-colors hover:border-primary/40"
        >
          <div class="flex items-center gap-2 text-xs text-muted">
            <span aria-hidden>{e.cover_emoji ?? "📰"}</span>
            <span>{fmtDate(e.published_at)}</span>
            {e.min_tier !== "free" && (
              <span class="rounded-full bg-primary/15 px-2 py-0.5 text-[10px] font-semibold text-primary">
                {TIER_LABEL[e.min_tier]}
              </span>
            )}
          </div>
          <h2 class="mt-2 text-lg font-bold">{e.title}</h2>
          <p class="mt-1.5 text-sm text-muted">{e.excerpt}</p>
          <span class="mt-3 inline-block text-sm text-primary">Ler edição →</span>
        </a>
      ))}
    </div>
  </section>
  <Footer />
</Base>
