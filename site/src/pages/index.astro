---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import { SIGNUP_URL, PRICING, MARKETS } from "../consts";

const brl = (n: number) => n.toLocaleString("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });

const FEATURES = [
  { icon: "📊", tier: "Pro", title: "Módulo Gamma", desc: "Regime de gamma, Zero Gamma, Max Pain e Call/Put Wall — os níveis institucionais, estilo SpotGamma." },
  { icon: "🌊", tier: "Pro", title: "Fluxo e alavancagem", desc: "Funding, CVD, long/short, liquidações, risco de squeeze e pressão do book do varejo — o posicionamento em semáforo." },
  { icon: "🌐", tier: "Pro", title: "Macro & Correlações", desc: "Correlação com DXY, Nasdaq, ouro e VIX, liquidez DeFi e calendário econômico global." },
  { icon: "🏦", tier: "Expert", title: "Camada institucional", desc: "Viés Coinbase × varejo, ETFs spot, hedge de opções, pressão do book institucional e heatmap de liquidação." },
  { icon: "🧠", tier: "Expert", title: "Smart Money & On-chain", desc: "Estrutura SMC, order blocks, liquidez, unlocks e atividade de rede — em qualquer moeda." },
  { icon: "✨", tier: "Todos", title: "IA + Alertas", desc: "A IA costura tudo numa narrativa em português. Alertas de preço, funding e gamma: in-app, push e e-mail (Expert)." },
];

const STEPS = [
  { n: "1", title: "Crie sua conta grátis", desc: "Comece pelo cockpit do BTC e pela newsletter semanal, sem cartão." },
  { n: "2", title: "Leia o mercado com clareza", desc: "Gamma, fluxo e liquidez traduzidos em semáforo — sem precisar ser quant." },
  { n: "3", title: "Suba quando quiser mais", desc: "Pro abre 20 ativos, gamma, macro e alertas. Expert adiciona a camada institucional, o fluxo avançado e o Smart Money." },
];

// Cor do selo de plano em cada recurso (qual plano libera).
const tierBadge = (tier: string) =>
  tier === "Expert"
    ? "bg-primary-strong text-white"
    : tier === "Pro"
      ? "bg-primary/15 text-primary"
      : "bg-surface text-muted border border-line";
---

<Base>
  <Nav />

  <!-- Hero -->
  <section class="glow relative overflow-hidden">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 lg:grid-cols-2 lg:py-28">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-line bg-card px-3 py-1 text-xs text-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-up"></span> Dados institucionais, leitura simples
        </span>
        <h1 class="mt-5 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl">
          O cockpit institucional<br /> dos <span class="text-primary">mercados</span>.
        </h1>
        <p class="mt-5 max-w-md text-lg text-muted">
          OrbeView traduz gamma, smart money e fluxo de capital em uma leitura clara — para você
          decidir com a visão de quem move o mercado. Cripto agora; ações (B3) e câmbio chegando.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={SIGNUP_URL} class="btn-glow rounded-lg bg-primary-strong px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-primary">
            Criar conta grátis
          </a>
          <a href="/precos" class="btn-glow rounded-lg border border-line px-5 py-3 text-sm font-semibold text-fg hover:bg-card">
            Ver planos
          </a>
        </div>
        <p class="mt-3 text-xs text-muted">Grátis para sempre no plano Free · sem cartão</p>
      </div>

      <!-- Mock do cockpit (SVG) -->
      <div class="relative">
        <div class="card-lift rounded-2xl border border-line bg-card/80 p-4 shadow-2xl backdrop-blur">
          <div class="mb-3 flex items-center justify-between text-xs text-muted">
            <span class="flex items-center gap-1.5 font-semibold text-fg"><span class="livedot"></span>BTC · Bitcoin</span>
            <span class="num">US$ 64.378,06</span>
          </div>
          <svg viewBox="0 0 320 170" class="mock-chart h-44 w-full" preserveAspectRatio="none">
            <!-- faixa heat (zona short acima / long abaixo) -->
            <rect x="0" y="18" width="320" height="26" fill="rgba(34,197,94,0.10)"></rect>
            <rect x="0" y="128" width="320" height="26" fill="rgba(239,68,68,0.10)"></rect>
            <!-- níveis -->
            <line x1="0" y1="30" x2="320" y2="30" stroke="#22c55e" stroke-width="1" stroke-dasharray="4 4"></line>
            <line x1="0" y1="86" x2="320" y2="86" stroke="#818cf8" stroke-width="1" stroke-dasharray="4 4"></line>
            <line x1="0" y1="140" x2="320" y2="140" stroke="#ef4444" stroke-width="1" stroke-dasharray="4 4"></line>
            <!-- velas -->
            <g stroke-width="5">
              <line x1="20" y1="70" x2="20" y2="120" stroke="#22c55e"></line>
              <line x1="40" y1="60" x2="40" y2="100" stroke="#22c55e"></line>
              <line x1="60" y1="64" x2="60" y2="112" stroke="#ef4444"></line>
              <line x1="80" y1="50" x2="80" y2="92" stroke="#22c55e"></line>
              <line x1="100" y1="44" x2="100" y2="78" stroke="#22c55e"></line>
              <line x1="120" y1="52" x2="120" y2="96" stroke="#ef4444"></line>
              <line x1="140" y1="58" x2="140" y2="104" stroke="#ef4444"></line>
              <line x1="160" y1="66" x2="160" y2="118" stroke="#22c55e"></line>
              <line x1="180" y1="60" x2="180" y2="98" stroke="#22c55e"></line>
              <line x1="200" y1="48" x2="200" y2="84" stroke="#22c55e"></line>
              <line x1="220" y1="54" x2="220" y2="100" stroke="#ef4444"></line>
              <line x1="240" y1="62" x2="240" y2="108" stroke="#ef4444"></line>
              <line x1="260" y1="70" x2="260" y2="116" stroke="#22c55e"></line>
              <line x1="280" y1="64" x2="280" y2="102" stroke="#22c55e"></line>
              <line x1="300" y1="58" x2="300" y2="94" stroke="#ef4444"></line>
            </g>
          </svg>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="rounded-full border border-up/30 bg-up/10 px-2 py-0.5 text-[10px] text-up">Call Wall 80k</span>
            <span class="rounded-full border border-primary/30 bg-primary/10 px-2 py-0.5 text-[10px] text-primary">Zero Gamma 65,4k</span>
            <span class="rounded-full border border-down/30 bg-down/10 px-2 py-0.5 text-[10px] text-down">Put Wall 60k</span>
          </div>
        </div>
        <div class="pointer-events-none absolute -bottom-3 -right-3 -z-10 h-full w-full rounded-2xl border border-line/60"></div>
      </div>
    </div>
  </section>

  <!-- Mercados -->
  <section id="mercados" class="border-y border-line/70 bg-surface/30">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-3 px-4 py-8 sm:gap-6">
      <span class="text-sm text-muted">Um cockpit, vários mercados:</span>
      {MARKETS.map((m) => (
        <span class="chip-lift inline-flex items-center gap-2 rounded-full border border-line bg-card px-3.5 py-1.5 text-sm">
          <span aria-hidden>{m.icon}</span>
          <span class="font-medium">{m.label}</span>
          <span class="text-[10px] uppercase tracking-wider text-muted">{m.note}</span>
        </span>
      ))}
    </div>
  </section>

  <!-- Recursos -->
  <section id="recursos" class="mx-auto max-w-6xl px-4 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight">As ferramentas que faltavam pro varejo</h2>
      <p class="mt-3 text-muted">O que antes só mesa institucional via — agora num semáforo que qualquer trader entende. O selo em cada recurso mostra o plano que o libera.</p>
    </div>
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((f) => (
        <div class="card-lift rounded-2xl border border-line bg-card p-6">
          <div class="flex items-start justify-between gap-3">
            <div class="icon-pop text-2xl" aria-hidden>{f.icon}</div>
            <span class={`rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${tierBadge(f.tier)}`}>{f.tier}</span>
          </div>
          <h3 class="mt-3 font-semibold">{f.title}</h3>
          <p class="mt-1.5 text-sm text-muted">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Como funciona -->
  <section class="border-y border-line/70 bg-surface/30">
    <div class="mx-auto max-w-6xl px-4 py-20">
      <div class="grid gap-10 md:grid-cols-3">
        {STEPS.map((s) => (
          <div class="step">
            <div class="step-num grid h-9 w-9 place-items-center rounded-full bg-primary-strong text-sm font-bold text-white">{s.n}</div>
            <h3 class="mt-4 text-lg font-semibold">{s.title}</h3>
            <p class="mt-1.5 text-sm text-muted">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Preços (teaser) -->
  <section id="precos" class="mx-auto max-w-6xl px-4 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight">Planos</h2>
      <p class="mt-3 text-muted">Comece grátis. Suba quando quiser o cockpit completo. Anual com 30% OFF de lançamento.</p>
    </div>
    <div class="mt-12 grid gap-5 lg:grid-cols-3">
      {PRICING.plans.map((p) => (
        <div class={`card-lift rounded-2xl border p-6 ${p.highlight ? "border-primary bg-card shadow-2xl ring-1 ring-primary/30" : "border-line bg-card"}`}>
          {p.highlight && <span class="mb-3 inline-block rounded-full bg-primary/15 px-2.5 py-0.5 text-[11px] font-semibold text-primary">Mais popular</span>}
          <h3 class="text-lg font-bold">{p.name}</h3>
          <p class="mt-1 text-sm text-muted">{p.tagline}</p>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="num text-3xl font-extrabold">{p.monthly === 0 ? "Grátis" : brl(p.monthly)}</span>
            {p.monthly > 0 && <span class="text-sm text-muted">/mês</span>}
          </div>
          <ul class="mt-5 space-y-2 text-sm">
            {p.features.map((f) => (
              <li class="flex gap-2 text-muted"><span class="text-up">✓</span><span>{f}</span></li>
            ))}
          </ul>
          <a
            href={p.slug === "free" ? SIGNUP_URL : `${SIGNUP_URL}?plan=${p.slug}`}
            class={`mt-6 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors ${p.highlight ? "bg-primary-strong text-white hover:bg-primary" : "border border-line text-fg hover:bg-surface"}`}
          >
            {p.cta}
          </a>
        </div>
      ))}
    </div>
    <p class="mt-6 text-center text-sm"><a href="/precos" class="text-primary hover:underline">Comparar planos em detalhe →</a></p>
  </section>

  <!-- Newsletter -->
  <section id="newsletter" class="border-y border-line/70 bg-surface/30">
    <div class="mx-auto max-w-2xl px-4 py-20 text-center">
      <h2 class="text-3xl font-bold tracking-tight">A leitura semanal do mercado</h2>
      <p class="mt-3 text-muted">
        Toda semana, uma edição traduzindo o que a mesa institucional está vendo — gamma, fluxo e
        liquidez. Grátis para quem tem conta.
      </p>
      <div class="mt-8"><NewsletterForm /></div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="mx-auto max-w-6xl px-4 py-24 text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Veja o mercado como a mesa vê.</h2>
    <p class="mx-auto mt-3 max-w-md text-muted">Crie sua conta grátis e abra o cockpit do BTC agora.</p>
    <a href={SIGNUP_URL} class="btn-glow mt-8 inline-block rounded-lg bg-primary-strong px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-primary">
      Começar grátis
    </a>
  </section>

  <Footer />
</Base>

<style>
  /* Mockup "ao vivo" da hero — movimento sutil. Respeita prefers-reduced-motion. */
  .mock-chart g line {
    animation: tick 2.8s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .mock-chart g line:nth-child(2n) { animation-duration: 3.4s; animation-delay: -0.6s; }
  .mock-chart g line:nth-child(3n) { animation-duration: 2.3s; animation-delay: -1.1s; }
  .mock-chart g line:nth-child(5n) { animation-delay: -1.7s; }
  .mock-chart > line { animation: flow 2.6s linear infinite; }
  .mock-chart > rect { animation: heat 4s ease-in-out infinite; }

  .livedot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
    animation: pulse 1.8s ease-out infinite;
  }

  /* Realce ao passar o mouse: cards/chips/botoes sobem e ganham brilho da marca */
  .card-lift { transition: transform .35s cubic-bezier(.2, .7, .2, 1), box-shadow .35s ease, border-color .35s ease; }
  .card-lift:hover {
    transform: translateY(-6px);
    border-color: rgba(129, 140, 248, .55);
    box-shadow: 0 0 0 1px rgba(129, 140, 248, .35), 0 24px 50px -18px rgba(99, 102, 241, .45);
  }
  .card-lift .icon-pop { transition: transform .35s cubic-bezier(.2, .7, .2, 1); }
  .card-lift:hover .icon-pop { transform: translateY(-3px) scale(1.12); }

  .chip-lift { transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease; }
  .chip-lift:hover {
    transform: translateY(-3px);
    border-color: rgba(129, 140, 248, .5);
    box-shadow: 0 10px 22px -10px rgba(99, 102, 241, .5);
  }

  .btn-glow { transition: transform .22s ease, box-shadow .22s ease, background-color .2s ease; }
  .btn-glow:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -10px rgba(99, 102, 241, .6); }
  .btn-glow:active { transform: translateY(0); }

  .step .step-num { transition: transform .3s ease, box-shadow .3s ease; }
  .step:hover .step-num { transform: translateY(-3px) scale(1.08); box-shadow: 0 12px 26px -8px rgba(99, 102, 241, .6); }

  @keyframes tick { 0%, 100% { transform: scaleY(1); } 50% { transform: scaleY(1.16); } }
  @keyframes flow { to { stroke-dashoffset: -16; } }
  @keyframes heat { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
    100% { box-shadow: 0 0 0 7px rgba(34, 197, 94, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mock-chart g line,
    .mock-chart > line,
    .mock-chart > rect,
    .livedot { animation: none; }
    .card-lift, .card-lift:hover, .card-lift .icon-pop, .card-lift:hover .icon-pop,
    .chip-lift, .chip-lift:hover, .btn-glow, .btn-glow:hover, .btn-glow:active,
    .step .step-num, .step:hover .step-num { transform: none; transition: none; }
  }
</style>
